# Copy this file to ".env" for local development, or set these as environment
# variables in Netlify (Site settings → Environment variables).
#
# The anon key is PUBLIC by design — it is safe to expose. Security is enforced
# by Row Level Security rules in the database (see db/schema.sql).

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: the email allowed to edit. Defaults to ottomahjong@gmail.com.
# VITE_OWNER_EMAIL=ottomahjong@gmail.com
